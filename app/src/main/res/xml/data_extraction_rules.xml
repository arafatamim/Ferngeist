<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Backups are disabled in the manifest (allowBackup=false) because the
         Room database contains plaintext tokens and credentials that must not
         be extractable via cloud backup or device transfer. These explicit
         exclusions are a defense-in-depth measure. -->
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>